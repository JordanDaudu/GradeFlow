# ============================================================
# GradeFlow — Docker environment variables
# Copy this file to .env and fill in real values.
# The .env file is gitignored and must never be committed.
# ============================================================

# --- PostgreSQL ---
# Credentials for the database container.
POSTGRES_USER=gradeflow
POSTGRES_PASSWORD=change_this_in_production
POSTGRES_DB=gradeflow

# Connection string assembled from the three vars above.
# The hostname "db" matches the docker-compose service name.
DATABASE_URL=postgresql://gradeflow:change_this_in_production@db:5432/gradeflow

# --- Backend ---
# Internal port the NestJS server listens on (used by docker-compose).
BACKEND_PORT=8080

# A long random string used to sign JWTs. Generate one with:
#   openssl rand -hex 64
JWT_SECRET=change_this_in_production_use_openssl_rand_hex_64

# Resend (https://resend.com) — used to send password-reset emails.
# If both are omitted, email sending is silently skipped.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=GradeFlow <noreply@yourdomain.com>

# The public URL where the frontend is reachable, used in password-reset email links.
FRONTEND_BASE_URL=http://localhost:3000

# --- Storage ---
# Selects the storage backend: "replit" (default, only works inside Replit) or "s3".
# docker-compose.yml overrides this to "s3" automatically — you do not need to set it here
# unless you are running the backend outside of Docker and want S3 storage.
STORAGE_BACKEND=s3
#
# The MinIO container (bundled in docker-compose.yml) provides local S3-compatible
# storage — no AWS account needed for local development or self-hosted deployments.
#
# MinIO credentials (also used as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD):
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
#
# Bucket name (created automatically on first start):
S3_BUCKET=gradeflow
#
# AWS region — any value works for MinIO:
S3_REGION=us-east-1
#
# S3_PUBLIC_ENDPOINT is the URL that the user's *browser* uses to upload files
# directly to MinIO. It must be reachable from the client machine.
# Default: http://localhost:9000 (works when running on the same machine).
# Change to your server's public IP or hostname for remote/production deployments.
S3_PUBLIC_ENDPOINT=http://localhost:9000
#
# MinIO web console port (access at http://localhost:9001 after docker compose up):
MINIO_CONSOLE_PORT=9001
#
# -----------------------------------------------------------------------
# To use a real AWS S3 bucket instead of the bundled MinIO container:
#   1. Remove or comment out the minio service in docker-compose.yml
#   2. Remove S3_ENDPOINT and S3_FORCE_PATH_STYLE from docker-compose.yml
#   3. Set real AWS credentials here:
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_BUCKET=my-gradeflow-bucket
# S3_REGION=us-east-1
# S3_PUBLIC_ENDPOINT=   (leave empty — standard AWS URLs are used)
# -----------------------------------------------------------------------

# --- Frontend ---
# Host port that the nginx container is published on.
FRONTEND_PORT=3000
